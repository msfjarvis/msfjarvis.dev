{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "github>msfjarvis/shared-workflows//renovate/automerge",
  ],
  packageRules: [
    {
      matchManagers: ["npm"],
      matchUpdateTypes: ["major"],
      enabled: false,
    },
  ],
  commitMessageSuffix: "[staging]",
}
