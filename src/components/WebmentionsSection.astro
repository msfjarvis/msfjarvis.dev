---
import { SITE_URL } from "../consts";

// This component is client-only to fetch fresh webmentions at request time
---

<div>
	<aside class="webmentions" data-site-url={SITE_URL}>
		<h3>Webmentions</h3>
		<div id="webmentions-container">
			<p>Loading webmentions...</p>
		</div>
	</aside>

	<script>
		(async function loadWebmentions() {
			const aside = document.querySelector('.webmentions');
			const heading = aside?.querySelector('h3');
			const container = document.getElementById('webmentions-container');
			if (!aside || !heading || !container) return;
			const siteUrl = aside.getAttribute('data-site-url');
			if (!siteUrl) return;

			interface Mention {
				id: number;
				verified_at: number;
				source: string;
				author?: { name?: string | null; url?: string | null; photo?: string | null } | null;
				content?: string | null;
				interaction_type?: string | null;
			}

			const escapeHtml = (value: string) =>
				value
					.replaceAll('&', '&amp;')
					.replaceAll('<', '&lt;')
					.replaceAll('>', '&gt;')
					.replaceAll('"', '&quot;')
					.replaceAll("'", '&#39;');

			const getAuthor = (mention: Mention) => {
				const author = mention.author || {};
				return {
					name: author.name || new URL(mention.source).hostname,
					url: author.url || mention.source,
					photo: author.photo,
				};
			};

			const renderSummaryRow = (label: string, mentions: Mention[]) => {
				if (mentions.length === 0) return '';
				const avatars = mentions.map((mention) => {
					const author = getAuthor(mention);
					const authorName = escapeHtml(author.name);
					const authorUrl = escapeHtml(author.url);
					const avatar = author.photo
						? `<img src="${escapeHtml(author.photo)}" alt="${authorName}" class="webmention-summary-avatar" loading="lazy">`
						: `<span class="webmention-summary-fallback">${authorName.slice(0, 1).toUpperCase()}</span>`;
					return `<a href="${authorUrl}" rel="nofollow ugc" class="webmention-summary-link" aria-label="${label} by ${authorName}">${avatar}</a>`;
				}).join('');

				return `
					<div class="webmention-summary-row">
						<span class="webmention-summary-label">${label}</span>
						<div class="webmention-summary-avatars">${avatars}</div>
					</div>
				`;
			};

			const renderDetailedMention = (mention: Mention) => {
				const timestamp = mention.verified_at * 1000;
				const date = new Date(timestamp).toLocaleDateString();
				const isoDate = new Date(timestamp).toISOString();
				const author = getAuthor(mention);
				const authorName = escapeHtml(author.name);
				const authorUrl = escapeHtml(author.url);
				const authorPhoto = author.photo ? escapeHtml(author.photo) : '';
				const sourceUrl = escapeHtml(mention.source);
				const content = mention.content ? escapeHtml(mention.content) : '';
				const avatarHtml = authorPhoto
					? `<img src="${authorPhoto}" alt="${authorName}" class="webmention-avatar" loading="lazy">`
					: `<div class="webmention-avatar webmention-avatar-fallback" aria-hidden="true">${authorName.slice(0, 1).toUpperCase()}</div>`;
				const contentHtml = content
					? `<p class="webmention-text">${content}</p>`
					: '';

				return `
					<article class="webmention-item">
						${avatarHtml}
						<div class="webmention-content">
							<div class="webmention-header">
								<a href="${authorUrl}" rel="nofollow ugc" class="webmention-author">${authorName}</a>
								<span class="webmention-separator">·</span>
								<time datetime="${isoDate}">${date}</time>
							</div>
							${contentHtml}
							<p class="webmention-meta"><a href="${sourceUrl}" rel="nofollow ugc" class="webmention-verb">via ${new URL(mention.source).hostname}</a></p>
						</div>
					</article>
				`;
			};

			// Always query webmentions for the canonical production page URL so
			// webmentions still resolve correctly when browsing the site in dev.
			const currentUrl = new URL(window.location.href);
			const pageUrl = new URL(`${currentUrl.pathname}${currentUrl.search}`, siteUrl).toString();

			try {
				const res = await fetch(`/api/webmentions.json?target=${encodeURIComponent(pageUrl)}`);
				const data = await res.json();

				if (!data.mentions || data.mentions.length === 0) {
					container.innerHTML = '<p>No webmentions yet. <a href="https://indieweb.org/Webmention">What are webmentions?</a></p>';
					return;
				}

				const mentions = data.mentions as Mention[];
				heading.innerHTML = `Webmentions <span>・${mentions.length} mention${mentions.length === 1 ? '' : 's'}</span>`;

				const likes = mentions.filter((mention) => mention.interaction_type === 'like');
				const reposts = mentions.filter((mention) => mention.interaction_type === 'repost');
				const detailedMentions = mentions.filter((mention) => {
					const type = mention.interaction_type;
					return type !== 'like' && type !== 'repost';
				});

				const summaryHtml = [
					renderSummaryRow('Liked by', likes),
					renderSummaryRow('Reposted by', reposts),
				].join('');

				const detailedHtml = detailedMentions
					.map((mention) => renderDetailedMention(mention))
					.join('');

				container.innerHTML = `${summaryHtml}${detailedHtml}`;
			} catch (err) {
				console.error('Webmention error:', err);
				container.innerHTML = '<p>Could not load webmentions.</p>';
			}
		})();
	</script>
</div>

<!--
 Need to be marked is:global so Astro emits them unmodified, otherwise they become data-astro-cid-xxxx which keels over
 in the presence of dynamically generated HTML elements like we do above.
 -->
<style is:global>
.webmentions {
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}
.webmentions h3 {
  color: var(--primary);
  margin-bottom: 1rem;
  font-size: 1rem;
}
.webmentions h3 span {
  color: var(--secondary);
  font-size: 0.95rem;
  font-weight: 400;
  margin-left: 0.2rem;
}
.webmention-summary-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin: 0 0 0.9rem;
  color: var(--secondary);
  font-size: 0.95rem;
}
.webmention-summary-label {
  min-width: fit-content;
}
.webmention-summary-avatars {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.webmention-summary-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 999px;
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--bg-subtle);
  box-shadow: none;
}
.webmention-summary-avatar,
.webmention-summary-fallback {
  width: 100%;
  height: 100%;
}
.webmention-summary-avatar {
  object-fit: cover;
}
.webmention-summary-fallback {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--primary);
}
.webmention-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  margin: 0;
  padding: 1rem 0;
  border-top: 1px solid var(--border);
  color: var(--content);
  font-size: 14px;
}
.webmention-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  flex-shrink: 0;
  object-fit: cover;
}
.webmention-avatar-fallback {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-subtle);
  color: var(--primary);
  font-size: 0.8rem;
  font-weight: 700;
}
.webmention-content {
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
  flex: 1;
  min-width: 0;
}
.webmention-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.35rem;
  color: var(--secondary);
  font-size: 0.95rem;
}
.webmention-separator {
  color: var(--secondary);
}
.webmention-text {
  margin: 0;
  color: var(--content);
  font-size: 1rem;
  line-height: 1.6;
}
.webmention-meta {
  margin: 0;
  color: var(--secondary);
  font-size: 0.9rem;
}
.webmention-author {
  color: var(--primary);
  font-weight: 600;
  text-decoration: none;
  box-shadow: none;
}
.webmention-author:hover {
  text-decoration: underline;
}
.webmention-verb {
  color: var(--secondary);
  text-decoration: none;
  box-shadow: none;
}
.webmention-verb:hover {
  color: var(--primary);
  text-decoration: underline;
}
.webmention-item time {
  color: var(--secondary);
}
</style>
