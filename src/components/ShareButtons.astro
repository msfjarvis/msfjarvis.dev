---
import { Icon } from 'astro-iconset/components';

interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;

// Encode URL and title for sharing
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

// Generate share URLs
const redditShareUrl = `https://reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`;
const shareText = encodeURIComponent(`${title} ${url}`);
const mastodonShareUrl = `https://share.joinmastodon.org/#text=${shareText}`;
---

<div class="share-buttons">
  <span class="share-label">Share on:</span>
  <a href={redditShareUrl} rel="noopener noreferrer" target="_blank" class="share-link reddit" title="Share on Reddit" aria-label="Share on Reddit">
    <Icon name="simple-icons:reddit" height="20" width="20" aria-hidden="true" />
  </a>
  <a href={mastodonShareUrl} rel="noopener noreferrer" target="_blank" class="share-link mastodon" title="Share on Mastodon" aria-label="Share on Mastodon">
    <Icon name="simple-icons:mastodon" height="20" width="20" aria-hidden="true" />
  </a>
</div>

<style>
  .share-buttons {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .share-label {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-2);
    white-space: nowrap;
  }

  .share-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--text-2);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: all 0.2s ease;
    border-bottom: none;
  }

  .share-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-subtle);
  }

  .share-link svg {
    width: 20px;
    height: 20px;
  }

  @media (max-width: 480px) {
    .share-buttons {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .share-label {
      flex-basis: 100%;
    }
  }
</style>
