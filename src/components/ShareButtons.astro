---
import { Icon } from 'astro-iconset/components';
import { shareButtons } from "../data/share-buttons.ts";

interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
---

<div class="share-buttons">
  <span class="share-label">Share on:</span>
  {shareButtons.map(button => (
    <a href={button.makeShareLink(title, url)} rel="noopener noreferrer" target="_blank" class="share-link" title={`Share on ${button.title}`} aria-label={`Share on ${button.title}`}>
      <Icon name={button.icon} height="20" width="20" aria-hidden="true" />
    </a>
  ))}
</div>

<style>
  .share-buttons {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .share-label {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-2);
    white-space: nowrap;
  }

  .share-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--text-2);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: all 0.2s ease;
    border-bottom: none;
  }

  .share-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-subtle);
  }

  .share-link svg {
    width: 20px;
    height: 20px;
  }

  @media (max-width: 480px) {
    .share-buttons {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .share-label {
      flex-basis: 100%;
    }
  }
</style>
