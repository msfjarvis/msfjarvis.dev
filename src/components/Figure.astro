---
import ImageModal from './ImageModal.astro';

interface Props {
  src: ImageMetadata | string;
  srcDark?: ImageMetadata | string;
  alt?: string;
  title?: string;
  small?: boolean;
}

type ImageMetadata = {
  src: string;
  width: number;
  height: number;
  format: string;
};

const { src, srcDark, alt = '', title, small = false } = Astro.props;
---

{typeof src === 'object' ? (
  <ImageModal src={src} srcDark={srcDark} alt={alt} title={title} small={small} />
) : (
  <figure>
    <picture>
      {srcDark && <source media="(prefers-color-scheme: dark)" srcset={typeof srcDark === 'object' ? srcDark.src : srcDark} />}
      <img class={small && 'half' || ''} src={src} alt={alt} />
    </picture>
    {title && <figcaption>{title}</figcaption>}
  </figure>
)}
