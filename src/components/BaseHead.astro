---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
import type { AlternateFeed } from '../consts';

interface Props {
  title: string;
  description: string;
  image?: string;
  alternateFeeds?: AlternateFeed[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = '/android-chrome-512x512.webp', alternateFeeds } = Astro.props;
// Hrefs rendered unconditionally below — excluded from alternateFeeds to prevent duplicates.
const GLOBAL_FEED_HREFS = new Set(['/rss.xml', '/atom.xml', '/feed.json']);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="canonical" href={canonicalURL} />
<meta name="generator" content={Astro.generator} />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />

<title>{title}</title>
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.url)} />

<link rel="alternate" type="application/rss+xml"   title={`${SITE_TITLE} — RSS`}       href={new URL('rss.xml',  Astro.site)} />
<link rel="alternate" type="application/atom+xml"  title={`${SITE_TITLE} — Atom`}      href={new URL('atom.xml', Astro.site)} />
<link rel="alternate" type="application/feed+json" title={`${SITE_TITLE} — JSON Feed`} href={new URL('feed.json',Astro.site)} />
{/* Section and section-less feeds from virtual:site-feeds — global feeds skipped, they're hardcoded above */}
{alternateFeeds
  ?.filter(f => !GLOBAL_FEED_HREFS.has(f.href))
  .map(f => (
    <link rel="alternate" type={f.type} title={f.title} href={new URL(f.href, Astro.site)} />
  ))
}

<div class="h-card" style="display: none;">
	<a class="u-url" href="https://msfjarvis.dev/"></a>
	<figure>
		<img class="nolink u-photo u-logo" src="/harsh-shandilya.webp">
		<figcaption>Harsh Shandilya's profile picture</figcaption>
	</figure>
	<p>I am <span class="p-name">Harsh Shandilya</span>. <span class="p-note">I'm a <span class="p-job-title">Systems Engineer</span> currently living in <span class="p-locality">Bangalore</span>, <span class="p-country-name">India</span>. I currently work at <span class="p-org"><a href="https://cloudflare.com" target="_blank" rel="noopener">Cloudflare</a></span>.</span></p>
	<a class="u-email" href="mailto:me@msfjarvis.dev"></a>
