---
import '../styles/global.css';
import '../styles/markdown-alert.css';
import { getImagePath } from 'astro-opengraph-images/util.js';
import type { AlternateFeed } from "../lib/feed.ts";

interface Props {
  title: string;
  description: string;
  image?: string;
  autoImage?: boolean;
  alternateFeeds?: AlternateFeed[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
  title,
  description,
  image,
  autoImage = false,
  alternateFeeds,
} = Astro.props;
const openGraphImage = image
  ? new URL(image, Astro.url)
  : autoImage
    ? getImagePath({ url: Astro.url, site: Astro.site })
    : new URL('/android-chrome-512x512.webp', Astro.url);
const feeds = alternateFeeds ?? [
  { type: 'application/rss+xml', title: 'Harsh Shandilya — RSS', href: '/rss.xml' },
  { type: 'application/atom+xml', title: 'Harsh Shandilya — Atom', href: '/atom.xml' },
  { type: 'application/feed+json', title: 'Harsh Shandilya — JSON Feed', href: '/feed.json' },
];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="canonical" href={canonicalURL} />
<meta name="generator" content={Astro.generator} />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />

<title>{title}</title>
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={openGraphImage} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={openGraphImage} />


<link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
<script is:inline type="module" src="/pagefind/pagefind-component-ui.js"></script>
<script is:inline defer src="https://stats01.msfjarvis.dev/script.js" data-website-id="8cec1982-7db5-4719-9b61-018401a7590d"></script>

{feeds.map(f => (
  <link rel="alternate" type={f.type} title={f.title} href={new URL(f.href, Astro.site)} />
))}

<link rel="me" href="https://fantastic.earth/@msfjarvis">
<link rel="me" href="https://codeberg.org/msfjarvis">
<link rel="me" href="https://github.com/msfjarvis">
<link href="https://webmentions.msfjarvis.dev/webmention" rel="webmention" />
<meta name="fediverse:creator" content="@msfjarvis@fantastic.earth" />
<meta name="bubbles:fediverse" content="@msfjarvis@fantastic.earth" />
