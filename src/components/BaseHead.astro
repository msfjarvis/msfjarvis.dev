---
import '../styles/global.css';
import { getImagePath } from 'astro-opengraph-images/util.js';
import { SITE_TITLE } from '../consts';
import type { AlternateFeed } from "../lib/feed.ts";

interface Props {
  title: string;
  description: string;
  image?: string;
  autoImage?: boolean;
  alternateFeeds?: AlternateFeed[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
  title,
  description,
  image,
  autoImage = false,
  alternateFeeds,
} = Astro.props;
const openGraphImage = image
  ? new URL(image, Astro.url)
  : autoImage
    ? getImagePath({ url: Astro.url, site: Astro.site })
    : new URL('/android-chrome-512x512.webp', Astro.url);
// Hrefs rendered unconditionally below — excluded from alternateFeeds to prevent duplicates.
const GLOBAL_FEED_HREFS = new Set(['/rss.xml', '/atom.xml', '/feed.json']);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="canonical" href={canonicalURL} />
<meta name="generator" content={Astro.generator} />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />

<title>{title}</title>
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={openGraphImage} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={openGraphImage} />

<script is:inline defer src="https://stats01.msfjarvis.dev/script.js" data-website-id="8cec1982-7db5-4719-9b61-018401a7590d"></script>

<link rel="alternate" type="application/rss+xml"   title={`${SITE_TITLE} — RSS`}       href={new URL('rss.xml',  Astro.site)} />
<link rel="alternate" type="application/atom+xml"  title={`${SITE_TITLE} — Atom`}      href={new URL('atom.xml', Astro.site)} />
<link rel="alternate" type="application/feed+json" title={`${SITE_TITLE} — JSON Feed`} href={new URL('feed.json',Astro.site)} />
{/* Section and section-less feeds from virtual:site-feeds — global feeds skipped, they're hardcoded above */}
{alternateFeeds
  ?.filter(f => !GLOBAL_FEED_HREFS.has(f.href))
  .map(f => (
    <link rel="alternate" type={f.type} title={f.title} href={new URL(f.href, Astro.site)} />
  ))
}

<link rel="me" href="https://androiddev.social/@msfjarvis">
<link rel="me" href="https://mstdn.games/@msfjarvis">
<link rel="me" href="https://codeberg.org/msfjarvis">
<link rel="me" href="https://github.com/msfjarvis">
<link href="https://webmentions.msfjarvis.dev/webmention" rel="webmention" />
<meta name="fediverse:creator" content="@msfjarvis@androiddev.social" />

<script is:inline>
  (() => {
    function bindMermaidModal(root) {
      if (!(root instanceof HTMLElement) || root.dataset.mermaidModalBound === 'true') return;
      root.dataset.mermaidModalBound = 'true';

      const trigger = root.querySelector('[data-mermaid-modal-trigger]');
      const dialog = root.querySelector('[data-mermaid-modal-container]');
      const closeButton = root.querySelector('[data-mermaid-modal-close]');
      const overlay = root.querySelector('[data-mermaid-modal-overlay]');

      if (!(trigger instanceof HTMLButtonElement) || !(dialog instanceof HTMLElement) || !(closeButton instanceof HTMLButtonElement) || !(overlay instanceof HTMLButtonElement)) return;

      let lastFocused = null;
      const lockScroll = () => {
        document.body.style.overflow = 'hidden';
      };
      const unlockScroll = () => {
        document.body.style.overflow = '';
      };
      const open = () => {
        lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : trigger;
        dialog.dataset.open = 'true';
        dialog.removeAttribute('inert');
        dialog.setAttribute('aria-hidden', 'false');
        lockScroll();
        closeButton.focus();
      };
      const close = () => {
        dialog.dataset.open = 'false';
        dialog.setAttribute('inert', '');
        dialog.setAttribute('aria-hidden', 'true');
        unlockScroll();
        lastFocused?.focus?.();
      };

      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        open();
      });
      closeButton.addEventListener('click', close);
      overlay.addEventListener('click', close);
      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) close();
      });
      dialog.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          event.preventDefault();
          close();
        }
      });
    }

    function initMermaidModals() {
      document.querySelectorAll('[data-mermaid-modal-root]').forEach(bindMermaidModal);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMermaidModals, { once: true });
    } else {
      initMermaidModals();
    }
  })();
</script>
