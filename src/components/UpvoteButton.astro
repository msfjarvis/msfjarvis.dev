---
interface Props {
  postId: string;
}

const { postId } = Astro.props;
const idPattern = /^[A-Za-z0-9][A-Za-z0-9._~/-]{0,127}$/;
if (typeof postId !== "string" || !idPattern.test(postId)) {
  throw new Error(
    "UpvoteButton postId must be 1–128 URL-safe characters and start with a letter or number",
  );
}
---

<upvote-button data-post-id={postId} aria-busy="true">
  <button type="button" data-upvote aria-pressed="false" disabled>
    <span class="upvote-button__arrow" aria-hidden="true">↑</span>
    <span>Upvote</span>
    <span class="upvote-button__count" data-count aria-label="vote count">…</span>
  </button>
  <span class="upvote-button__status" data-status aria-live="polite" aria-atomic="true"
    >Loading votes…</span
  >
  <button type="button" data-retry aria-label="Retry loading upvotes" hidden>Retry</button>
</upvote-button>

<style>
  upvote-button {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem 0.75rem;
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    color: var(--text-2);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.35rem;
    padding: 0.4rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    color: var(--text-2);
    font: inherit;
    cursor: pointer;
    transition:
      border-color 120ms ease,
      color 120ms ease,
      background-color 120ms ease;
  }

  button:hover:not(:disabled) {
    border-color: var(--accent-subtle);
    color: var(--accent);
    background: var(--bg-subtle);
  }

  button[aria-pressed="true"] {
    border-color: var(--accent-subtle);
    background: var(--accent-subtle);
    color: var(--accent);
  }

  button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  button:disabled {
    cursor: wait;
    opacity: 0.65;
  }

  .upvote-button__arrow {
    font-size: 1rem;
    line-height: 1;
  }

  .upvote-button__count {
    min-width: 1.5em;
    padding-left: 0.45rem;
    border-left: 1px solid currentColor;
    text-align: center;
  }

  .upvote-button__status {
    color: var(--text-2);
    line-height: 1.4;
  }

  button[hidden] {
    display: none;
  }

  .upvote-button__status[data-error="true"] {
    color: var(--accent);
  }

  @media (prefers-reduced-motion: reduce) {
    button {
      transition: none;
    }
  }
</style>

<script>
  import type { VoteSummary } from "../lib/votes.ts";
  import {
    clearVote,
    fetchVoteSummary,
    submitVote,
    VoteApiError,
  } from "../lib/votes-client.ts";

  class UpvoteButtonElement extends HTMLElement {
    private summary: Extract<VoteSummary, { type: "upvote" }> | null = null;
    private busy = false;

    connectedCallback() {
      if (this.dataset.initialized === "true") return;
      this.dataset.initialized = "true";

      const button = this.querySelector("[data-upvote]");
      const retry = this.querySelector("[data-retry]");
      if (!(button instanceof HTMLButtonElement) || !(retry instanceof HTMLButtonElement)) return;
      button.addEventListener("click", () => void this.toggle());
      retry.addEventListener("click", () => void this.load());
      void this.load();
    }

    private get postId(): string {
      return this.dataset.postId ?? "";
    }

    private async load() {
      this.setBusy(true);
      this.setStatus("Loading votes…");
      try {
        const summary = await fetchVoteSummary({ type: "upvote", postId: this.postId });
        if (summary.type !== "upvote") throw new VoteApiError("Invalid upvote response");
        this.summary = summary;
        this.renderSummary();
        this.setStatus("");
        this.setRetryVisible(false);
      } catch (error) {
        this.setStatus(errorMessage(error), true);
        this.setRetryVisible(true);
      } finally {
        this.setBusy(false);
      }
    }

    private async toggle() {
      if (this.busy || this.summary === null) return;
      const wasVoted = this.summary.voted;
      this.setBusy(true);
      this.setStatus(wasVoted ? "Removing upvote…" : "Adding upvote…");

      try {
        const summary = wasVoted
          ? await clearVote({ type: "upvote", postId: this.postId })
          : await submitVote({ type: "upvote", postId: this.postId });
        if (summary.type !== "upvote") throw new VoteApiError("Invalid upvote response");
        this.summary = summary;
        this.renderSummary();
        this.setStatus(wasVoted ? "Upvote removed." : "Upvote added.");
      } catch (error) {
        this.setStatus(errorMessage(error), true);
      } finally {
        this.setBusy(false);
      }
    }

    private renderSummary() {
      if (this.summary === null) return;
      const button = this.querySelector("[data-upvote]");
      const count = this.querySelector("[data-count]");
      if (!(button instanceof HTMLButtonElement) || !(count instanceof HTMLElement)) return;

      button.setAttribute("aria-pressed", String(this.summary.voted));
      count.textContent = this.summary.total.toLocaleString();
      count.setAttribute(
        "aria-label",
        `${this.summary.total.toLocaleString()} ${this.summary.total === 1 ? "vote" : "votes"}`,
      );
    }

    private setBusy(busy: boolean) {
      this.busy = busy;
      this.setAttribute("aria-busy", String(busy));
      const button = this.querySelector("[data-upvote]");
      if (button instanceof HTMLButtonElement) button.disabled = busy || this.summary === null;
      const retry = this.querySelector("[data-retry]");
      if (retry instanceof HTMLButtonElement) retry.disabled = busy;
    }

    private setRetryVisible(visible: boolean) {
      const retry = this.querySelector("[data-retry]");
      if (retry instanceof HTMLButtonElement) retry.hidden = !visible;
    }

    private setStatus(message: string, isError = false) {
      const status = this.querySelector("[data-status]");
      if (!(status instanceof HTMLElement)) return;
      status.textContent = message;
      status.toggleAttribute("data-error", isError);
    }
  }

  function errorMessage(error: unknown): string {
    return error instanceof Error ? error.message : "Could not update this upvote. Please try again.";
  }

  if (!customElements.get("upvote-button")) {
    customElements.define("upvote-button", UpvoteButtonElement);
  }
</script>
