---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PagefindConfig from '../components/PagefindConfig.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import type { AlternateFeed } from "../lib/feed.ts";

interface Props {
  title?: string;
  description?: string;
  alternateFeeds?: AlternateFeed[];
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  alternateFeeds,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} alternateFeeds={alternateFeeds} />
    <script is:inline>
      const applyPagefindTheme = (isDark) => {
        document.documentElement.toggleAttribute("data-pf-theme", isDark);
        if (isDark) {
          document.documentElement.setAttribute("data-pf-theme", "dark");
          document.body?.setAttribute("data-pf-theme", "dark");
        } else {
          document.documentElement.removeAttribute("data-pf-theme");
          document.body?.removeAttribute("data-pf-theme");
        }
      };

      const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
      applyPagefindTheme(mediaQuery.matches);
      mediaQuery.addEventListener("change", (event) => applyPagefindTheme(event.matches));
    </script>
  </head>
  <body>
    <div class="h-card" style="display: none;" data-pagefind-ignore="all">
      <a class="u-url" href="https://msfjarvis.dev/"></a>
      <figure>
        <img class="nolink u-photo u-logo" src="/harsh-shandilya.webp" alt="" />
        <figcaption>Harsh Shandilya's profile picture</figcaption>
      </figure>
      <p>
        I am <span class="p-name">Harsh Shandilya</span>.
        <span class="p-note"
          >I'm a <span class="p-job-title">Systems Engineer</span> currently living in
          <span class="p-locality">Bangalore</span>, <span class="p-country-name">India</span>.
          I currently work at
          <span class="p-org"
            ><a href="https://cloudflare.com" target="_blank" rel="noopener">Cloudflare</a></span
          >.</span
        >
      </p>
      <a class="u-email" href="mailto:me@msfjarvis.dev"></a>
      <div class="p-adr h-adr">
        <span class="p-country-name">India</span>
      </div>
      <a class="u-url" href="https://fantastic.earth/@msfjarvis" rel="me"></a>
      <a class="u-uid" href="https://msfjarvis.dev"></a>
    </div>
    <PagefindConfig />
    <Header />
    <main>
      <slot />
    </main>
    <pagefind-modal reset-on-close></pagefind-modal>
    <Footer />
  </body>
</html>
