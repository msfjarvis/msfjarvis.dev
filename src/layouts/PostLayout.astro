---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { slugify } from '../utils';
import WebmentionsSection from '../components/WebmentionsSection.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  date: Date;
  lastmod?: Date;
  minutesRead?: number;
  tags?: string[];
  image?: string;
  autoImage?: boolean;
  collection?: 'posts' | 'notes' | 'weeknotes';
  headings?: Heading[];
}

const {
  title,
  description,
  date,
  lastmod,
  minutesRead,
  tags,
  image,
  autoImage = false,
  collection,
  headings = [],
} = Astro.props;
const tocHeadings = headings;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description ?? title} image={image} autoImage={autoImage} />
    <style is:inline>
      .post-header {
        border-bottom: 1px solid var(--border);
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
      }

      .prose > * {
        margin-block: 0;
      }

      .prose > * + * {
        margin-block-start: 1rem;
      }

      .prose > hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2rem 0;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <article class="h-entry">
        <header class="post-header">
          <h1 class="p-name">{title}</h1>
          <p class="post-meta">
            <FormattedDate date={date} class="dt-published" />
            {lastmod && lastmod.getTime() !== date.getTime() && (
              <> · updated <FormattedDate date={lastmod} class="dt-updated" /></>
            )}
            {minutesRead != null && minutesRead > 0 && <> · {minutesRead} min read</>}
          </p>
          <span hidden data-og-date={date.toISOString()}></span>
          {collection && <span hidden data-og-collection={collection}></span>}
          <span class="p-author h-card" hidden>
            <img class="u-photo" src="/harsh-shandilya.webp" alt="" />
            <a class="p-name u-url" href="/">Harsh Shandilya</a>
          </span>
          <a class="u-url" href={Astro.url.pathname} hidden aria-hidden="true"></a>
          {description && <p class="p-summary" hidden>{description}</p>}
          {tags && tags.length > 0 && (
            <ul class="tags">
              {tags.map(tag => (
                <li class="tag p-category">
                  <a href={`/tags/${slugify(tag)}/`}>{tag}</a>
                </li>
              ))}
            </ul>
          )}
        </header>
        {tocHeadings.length > 0 && (
          <aside class="post-toc" aria-label="Table of contents">
            <div class="post-toc-inner">
              <p class="post-toc-title">On this page</p>
              <ul>
                {tocHeadings.map(({ depth, slug, text }) => (
                  <li class:list={[`depth-${depth}`]}>
                    <a href={`#${slug}`}>{text}</a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )}
        <div class="prose e-content">
          <slot />
        </div>
        <WebmentionsSection />
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  .post-toc {
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .post-toc-inner {
    display: grid;
    gap: 0.5rem;
  }

  .post-toc-title {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }

  .post-toc li {
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .post-toc li.depth-2 {
    padding-left: 0.75rem;
  }

  .post-toc li.depth-3 {
    padding-left: 1.5rem;
  }

  .post-toc a {
    color: var(--text-2);
    border-bottom: none;
    text-decoration: none;
  }

  .post-toc a:hover {
    color: var(--accent);
  }
  .post-header h1 {
    font-size: 1.4rem;
    margin-top: 0;
    margin-bottom: 0.4rem;
  }
  .post-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-2);
    margin: 0;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.15em 0.5em;
  }
  .tag a {
    color: var(--text-2);
    border-bottom: none;
  }
  .tag a:hover {
    color: var(--accent);
  }

  @media (min-width: 1400px) {
    .post-toc {
      position: fixed;
      top: 50vh;
      left: calc(50% + (var(--max-width) / 2) + 2rem);
      transform: translateY(-50%);
      width: 12rem;
      max-height: calc(100vh - 4rem);
      overflow: auto;
      margin-top: 0;
      margin-bottom: 0;
      padding-bottom: 0;
      padding-left: 1rem;
      border-bottom: none;
      border-left: 1px solid var(--border);
    }
  }
</style>
