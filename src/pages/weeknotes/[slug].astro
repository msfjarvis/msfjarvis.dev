---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import WebmentionsSection from '../../components/WebmentionsSection.astro';

export async function getStaticPaths() {
  const showDrafts = import.meta.env.DEV || import.meta.env.INCLUDE_DRAFTS === 'true';
  const weeknotes = await getCollection('weeknotes', (w) => !w.data.deleted && (showDrafts || !w.data.draft));
  return weeknotes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<PostLayout
  title={entry.data.title}
  description={entry.data.summary}
  date={entry.data.date}
  lastmod={entry.data.lastmod}
  tags={entry.data.tags}
>
  <Content />
  <WebmentionsSection />
</PostLayout>
