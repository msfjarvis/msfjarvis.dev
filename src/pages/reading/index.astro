---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = true;

const books = await getCollection("readBooks");
const bookCount = new Intl.NumberFormat("en-US").format(books.length);

function yearOf(date: Date | undefined) {
  return date?.getFullYear();
}
---

<BaseLayout
  title="Reading"
  description="Books Harsh Shandilya has marked as read on BookWyrm."
>
  <header class="page-header">
    <p class="eyebrow">BookWyrm shelf</p>
    <h1>Reading</h1>
    <p class="lede">
      {bookCount} books I’ve marked as read. Each one links back to its entry on BookWyrm.
    </p>
  </header>

  {
    books.length > 0 ? (
      <ol class="book-grid">
        {books.map((book) => {
          const { authors, cover, firstPublishedDate, publishedDate, series, seriesNumber, title, work } =
            book.data;
          const authorNames = authors.filter(
            (author) => !author.startsWith("http://") && !author.startsWith("https://"),
          );
          const publicationYear = yearOf(publishedDate) ?? yearOf(firstPublishedDate);
          const seriesLabel = series && seriesNumber ? `${series} #${seriesNumber}` : series;

          return (
            <li class="book">
              <a class="book-link" href={work}>
                <div class="cover-frame">
                  <span class="cover-placeholder" aria-hidden="true">{title}</span>
                  <img
                    class="cover"
                    src={cover.url}
                    alt={cover.name || `Cover of ${title}`}
                    loading="lazy"
                    decoding="async"
                    onerror="this.setAttribute('data-error', '')"
                  />
                </div>
                <div class="details">
                  <h2>{title}</h2>
                  {authorNames.length > 0 && <p class="authors">{authorNames.join(", ")}</p>}
                  {(seriesLabel || publicationYear) && (
                    <p class="publication">
                      {seriesLabel && <span>{seriesLabel}</span>}
                      {seriesLabel && publicationYear && <span aria-hidden="true"> · </span>}
                      {publicationYear && <time datetime={`${publicationYear}`}>{publicationYear}</time>}
                    </p>
                  )}
                </div>
              </a>
            </li>
          );
        })}
      </ol>
    ) : (
      <p class="empty">No books here yet.</p>
    )
  }
</BaseLayout>

<style>
  .page-header {
    max-width: 42rem;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    margin: 0 0 0.25rem;
    color: var(--text-3);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin-top: 0;
  }

  .lede {
    color: var(--text-2);
  }

  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: 2rem 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .book-link {
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100%;
    color: inherit;
    border: 0;
  }

  .book-link:hover h2,
  .book-link:focus-visible h2 {
    color: var(--accent);
  }

  .book-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .cover-frame {
    position: relative;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--bg-subtle);
    box-shadow: 3px 4px 0 var(--accent-subtle);
    transition: box-shadow 150ms ease, transform 150ms ease;
  }

  .cover-placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 1rem;
    color: var(--text-2);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.4;
    text-align: center;
  }

  .cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: var(--bg-subtle);
    object-fit: cover;
  }

  .cover[data-error] {
    opacity: 0;
  }

  .book-link:hover .cover-frame,
  .book-link:focus-visible .cover-frame {
    box-shadow: 5px 6px 0 var(--accent-subtle);
    transform: translate(-2px, -2px);
  }

  .details {
    padding-top: 0.75rem;
  }

  h2 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.35;
    transition: color 150ms ease;
  }

  .authors,
  .publication {
    margin: 0.35rem 0 0;
    color: var(--text-2);
    font-size: 0.85rem;
    line-height: 1.45;
  }

  .publication {
    color: var(--text-3);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .empty {
    color: var(--text-2);
  }

  @media (min-width: 640px) {
    .book-grid {
      grid-template-columns: repeat(auto-fill, minmax(11.5rem, 1fr));
      gap: 2.5rem 1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cover-frame,
    h2 {
      transition: none;
    }

    .book-link:hover .cover-frame,
    .book-link:focus-visible .cover-frame {
      transform: none;
    }
  }
</style>
