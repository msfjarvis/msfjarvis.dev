---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Book from "../../components/Book.astro";

export const prerender = true;

const currentlyReading = await getCollection("currentlyReading");
const readBooks = await getCollection("readBooks");
const bookCount = new Intl.NumberFormat("en-US").format(readBooks.length);
---

<BaseLayout
  title="Reading"
  description="Books Harsh Shandilya has marked as read on BookWyrm."
>
  <h2>currently reading</h2>
  <ol class="book-grid">
    {currentlyReading.map((book) => ( <Book book={book.data} /> ))}
  </ol>

  <h2>finished reading</h2>
  <p class="lede">
    {bookCount} books I’ve marked as read. Each one links back to its entry on BookWyrm.
  </p>
  {
    readBooks.length > 0 ? (
      <ol class="book-grid">
        {readBooks.map((book) => ( <Book book={book.data} /> ))}
      </ol>
    ) : (
      <p class="empty">No books here yet.</p>
    )
  }
</BaseLayout>

<style>
  .h2 {
    margin: 0 0 0.25rem;
    color: var(--text-3);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lede {
    color: var(--text-2);
  }

  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: 2rem 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
</style>
