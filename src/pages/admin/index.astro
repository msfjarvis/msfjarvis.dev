---
// CMS admin page — not indexed, not part of the public site.
// Sveltia CMS is loaded via CDN script tag so Astro/Vite never tries to bundle it.
// The config, custom.js, and tombstone.js are served from public/admin/ as static files.

export const prerender = true;
---

<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link href="/admin/config.yml" type="text/yaml" rel="cms-config-url" />
    <title>Content Manager</title>
  </head>
  <body>
    <script src="https://unpkg.com/@sveltia/cms@0.158.1/dist/sveltia-cms.js" type="module"></script>
    <script type="module" src="/admin/custom.js"></script>
  </body>
</html>
