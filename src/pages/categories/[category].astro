---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { slugify } from '../../utils';
import { filterDrafts } from '../../utils';

export const prerender = true;

export async function getStaticPaths() {
  const [posts, weeknotes] = await Promise.all([
    getCollection('posts',     filterDrafts),
    getCollection('weeknotes', filterDrafts),
  ]);

  const catMap = new Map<string, { title: string; date: Date; url: string }[]>();

  const addEntries = (entries: typeof posts, urlBase: string) => {
    for (const entry of entries) {
      for (const cat of entry.data.categories) {
        if (!catMap.has(cat)) catMap.set(cat, []);
        catMap.get(cat)!.push({
          title: entry.data.title,
          date: entry.data.date,
          url: `${urlBase}/${entry.id}/`,
        });
      }
    }
  };

  addEntries(posts,     '/posts');
  addEntries(weeknotes, '/weeknotes');

  return [...catMap.entries()].map(([category, entries]) => ({
    params: { category: slugify(category) },
    props: {
      category,
      entries: entries.sort((a, b) => b.date.getTime() - a.date.getTime()),
    },
  }));
}

const { category, entries } = Astro.props;
---

<BaseLayout title={`${category} — Categories`} description={`Posts in ${category}`}>
  <h1><a href="/categories/">Categories</a> <span class="sep">›</span> {category}</h1>
  <p class="count">{entries.length} {entries.length === 1 ? 'entry' : 'entries'}</p>
  <ul>
    {entries.map(({ title, date, url }) => (
      <li class="entry-row">
        <a href={url}>{title}</a>
        <span class="date"><FormattedDate date={date} /></span>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  h1 { margin-top: 0; margin-bottom: 0.25rem; }
  h1 a { color: var(--text-2); border-bottom: none; }
  h1 a:hover { color: var(--accent); }
  .sep { color: var(--text-2); margin: 0 0.25em; font-weight: 400; }
  .count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-2);
    margin: 0 0 1.5rem;
  }
  ul { list-style: none; padding: 0; margin: 0; }
  .entry-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    gap: 0.75rem;
  }
  .entry-row:last-child { border-bottom: none; }
  .entry-row a {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    border-bottom: none;
  }
  .entry-row a:hover { color: var(--text); }
  .date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-2);
    flex-shrink: 0;
  }
</style>
