{{- $entries := slice -}}
{{- range sort site.RegularPages "File.Path" -}}
  {{- if in (slice "posts" "notes") .Section -}}
    {{- $entries = $entries | append (dict "source" (printf "content/%s" .File.Path) "url" .Permalink) -}}
  {{- end -}}
{{- end -}}
{{- dict
  "schemaVersion" 1
  "siteOrigin" (strings.TrimSuffix "/" site.BaseURL)
  "generatedAt" (now.UTC.Format "2006-01-02T15:04:05Z07:00")
  "entries" $entries
| jsonify -}}
